# Postgres connection string (Neon, Supabase, or any Postgres)
# e.g. postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=""

# Google Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Optional: override the Gemini model (defaults to gemini-2.5-flash)
# GEMINI_MODEL="gemini-2.5-flash"

# Auth.js session encryption secret — generate with: npx auth secret
# (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=""

# Set to your public URL in production, e.g. https://daybook.example.com
# AUTH_URL="https://your-domain.com"
